# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# NODE_ENV: Set to 'production' or 'development'
NODE_ENV="development"

# LOG_LEVEL: error, warn, info, debug
LOG_LEVEL="info"

# SUPABASE_PROJECT_ID: The project ref for your Supabase instance
SUPABASE_PROJECT_ID="your-project-id"

# SUPABASE_JWT_SECRET: Secure verification secret from Supabase Settings API
SUPABASE_JWT_SECRET="your-supabase-jwt-secret"

# VITE_SUPABASE_URL: Public client URL for Supabase
VITE_SUPABASE_URL="https://your-supabase-project.supabase.co"

# VITE_SUPABASE_ANON_KEY: Public anonymous key for client requests
VITE_SUPABASE_ANON_KEY="your-supabase-anon-key"

# SUPABASE_SERVICE_ROLE_KEY: Backend bypass key to edit profiles/billing rows
SUPABASE_SERVICE_ROLE_KEY="your-supabase-service-role-key"

# VITE_RAZORPAY_KEY_ID: Public Key ID from Razorpay Settings
VITE_RAZORPAY_KEY_ID="rzp_test_your_key_id"

# RAZORPAY_KEY_SECRET: Secure Merchant Key Secret
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"

# RAZORPAY_WEBHOOK_SECRET: Signing verification key for webhook payload checks
RAZORPAY_WEBHOOK_SECRET="your_razorpay_webhook_secret"

# WEBHOOK_BASE_URL: Public URL where webhook listener will run
WEBHOOK_BASE_URL="https://your-public-url.com"

# VITE_GTM_ID: Google Tag Manager / GA4 Container ID
VITE_GTM_ID="GTM-XXXXXXXX"

# VITE_CLARITY_ID: Microsoft Clarity project ID
VITE_CLARITY_ID="xxxxxxxxxx"

# VITE_GOOGLE_VERIFICATION_ID: Google Search Console verification code
VITE_GOOGLE_VERIFICATION_ID="xxxxxxxxxxxxxxxxxxxx"

